type ProjectExport = { slug: string } & Record<string, unknown>;

function projectsListFromExport(projects: unknown, sourceLabel: string): ProjectExport[] {
  if (Array.isArray(projects)) {
    const list = projects as ProjectExport[];
    for (const p of list) {
      if (!p || typeof p !== "object" || typeof p.slug !== "string" || !p.slug.trim()) {
        throw new Error(`${sourceLabel}: each projectsData.projects entry must be an object with a non-empty slug`);
      }
    }
    return list;
  }
  if (projects && typeof projects === "object") {
    return Object.entries(projects as Record<string, ProjectExport>).map(([slug, p]) => {
      if (!p || typeof p !== "object") throw new Error(`${sourceLabel}: invalid project at key "${slug}"`);
      const resolvedSlug = typeof p.slug === "string" && p.slug.trim() ? p.slug : slug;
      return { ...p, slug: resolvedSlug };
    });
  }
  throw new Error(`${sourceLabel}: projectsData.projects must be an array in _data-export.*.json`);
}

function buildMessages(ui: typeof uiEn, data: typeof dataEn) {
  const projectList = projectsListFromExport(data.projectsData.projects, "projectsData");
  const projectsRecord: Record<string, ProjectExport> = {};
  for (const p of projectList) {
    if (projectsRecord[p.slug]) throw new Error(`Duplicate project slug in export data: ${p.slug}`);
    projectsRecord[p.slug] = p;
  }
  const { companies: companiesData, projects: _dataProjects, projectsData: _rawProjectsData, ...restData } = data as typeof dataEn & { companies: unknown[]; projects?: unknown; projectsData?: unknown };
  return { ...restData, ...ui, companies: ui.companies, projects: ui.projects, companiesData, projectsData: { projectTypeLabels: data.projectsData.projectTypeLabels, projects: projectsRecord } };
}

mkdirSync(join(root, "messages"), { recursive: true });
const en = buildMessages(uiEn, dataEn);
const fa = buildMessages(uiFa, dataFa);
const ps = buildMessages(uiPs, dataPs);
const usedKeys = scanSourceTranslationKeys();
for (const [locale, messages] of [["en", en], ["fa-AF", fa], ["ps", ps]] as const) assertAllKeysPresent(messages as Record<string, unknown>, locale, usedKeys);
const localeFiles = { en, "fa-AF": fa, ps } as const;
for (const [locale, messages] of Object.entries(localeFiles)) {
  const path = join(root, "messages", `${locale}.json`);
  writeFileSync(path, JSON.stringify(messages, null, 2));
  if (!existsSync(path)) throw new Error(`Failed to write ${path}`);
}
console.log(`Built en.json, fa-AF.json, ps.json (${usedKeys.length} keys validated against src/)`);
